# Wolf Trading OS — environment configuration template.
# Copy to `.env` and adjust. NEVER commit a real .env file.

# development | test | staging | production
# database-reset-dev is hard-blocked unless this is "development".
WTOS_ENVIRONMENT=development

# PostgreSQL connection (psycopg3 driver).
# docker-compose supplies its own value pointing at the `db` service.
WTOS_DATABASE_URL=postgresql+psycopg://wolf:wolf@localhost:5432/wolf_trading_os_dev

# json | console
WTOS_LOG_FORMAT=json
WTOS_LOG_LEVEL=INFO

# Used by docker-compose to initialize the Postgres container.
POSTGRES_USER=wolf
POSTGRES_PASSWORD=wolf
POSTGRES_DB=wolf_trading_os_dev
